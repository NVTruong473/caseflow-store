# Required public Supabase runtime values. These are bundled for browser use.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional public canonical site URL for metadata, robots, and sitemap output.
# Defaults to https://caseflow-store.vercel.app.
# NEXT_PUBLIC_SITE_URL=https://caseflow-store.vercel.app

# Public single-store identity. These values are safe to include in the client
# bundle. Leave support phone/email unset until the deployment owner supplies
# monitored, real contact channels; the UI omits them when absent.
# NEXT_PUBLIC_STORE_NAME=CaseFlow Books
# NEXT_PUBLIC_STORE_SHORT_MARK=CB
# NEXT_PUBLIC_STORE_TAGLINE_EN=Bilingual bookstore
# NEXT_PUBLIC_STORE_TAGLINE_VI=Nhà sách song ngữ
# NEXT_PUBLIC_STORE_SUPPORT_PHONE=
# NEXT_PUBLIC_STORE_SUPPORT_EMAIL=
# NEXT_PUBLIC_STORE_SUPPORT_HOURS_EN=Mon-Sat, 09:00-18:00 ICT
# NEXT_PUBLIC_STORE_SUPPORT_HOURS_VI=Thứ 2-Thứ 7, 09:00-18:00 ICT
# NEXT_PUBLIC_STORE_LEGAL_NAME=CaseFlow Books
# NEXT_PUBLIC_STORE_COPYRIGHT_YEAR=2026

# Required server-only runtime value. Never expose it through NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Management API token for one-off operational scripts only.
# Do not deploy this to the browser and do not commit a real token.
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_PROJECT_REF=

# Custom SMTP for Supabase Auth. Use real provider credentials only.
# Run `AUTH_SMTP_APPLY=true npm exec -- tsx scripts/configure-supabase-custom-smtp.ts`
# only from a trusted local shell after these are set.
# SMTP_ADMIN_EMAIL=no-reply@example.com
# SMTP_HOST=smtp.provider.example
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SENDER_NAME=CaseFlow Books

# Playwright only. Leave these unset in the deployed application runtime.
CASEFLOW_ADMIN_EMAIL=
CASEFLOW_ADMIN_PASSWORD=

# Optional Playwright overrides. Defaults are port 3001 and its local base URL.
# PLAYWRIGHT_PORT=3001
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3001

# Optional server-owned display estimates for English-mode approximate USD.
# VND remains the authoritative stored currency.
# Defaults use HSBC Vietnam USD/VND telegraphic selling rate published at
# 2026-07-16 08:35 ICT, plus configurable estimate assumptions.
# CASEFLOW_FX_VND_PER_USD=26400
# CASEFLOW_FX_SOURCE_LABEL=HSBC Vietnam telegraphic selling rate
# CASEFLOW_FX_SOURCE_URL=https://www.hsbc.com.vn/en-vn/foreign-exchange/rate/
# CASEFLOW_FX_QUOTED_AT=2026-07-16T08:35:00+07:00
# CASEFLOW_VAT_BASIS_POINTS=1000
# CASEFLOW_INTL_PAYMENT_FEE_BASIS_POINTS=300

# QR payment sandbox. Keep these as demo/sandbox values only.
# Production must not enable mock payment success controls.
PAYMENT_MODE=demo
ENABLE_MOCK_PAYMENT=true
CASEFLOW_MERCHANT_NAME=CaseFlow Books
DEMO_BANK_BIN=970436
DEMO_BANK_NAME=Vietcombank
DEMO_BANK_ACCOUNT_NUMBER=0000000000
DEMO_BANK_ACCOUNT_NAME=
DEMO_PAYMENT_EXPIRES_MINUTES=15
MOCK_PAYMENT_WEBHOOK_SECRET=change-me-in-development

# Transactional notifications. In-app notifications remain available when
# external delivery is disabled. Sandbox renders staff-only previews and never
# contacts email or SMS networks. Production should remain disabled until all
# live-provider credentials and sender approvals are complete.
NOTIFICATION_MODE=disabled
EMAIL_PROVIDER=disabled
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=
SMS_PROVIDER=disabled
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM=
OTP_HASH_SECRET=
NOTIFICATION_DISPATCH_SECRET=
