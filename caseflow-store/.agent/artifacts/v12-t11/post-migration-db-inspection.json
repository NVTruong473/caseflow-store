      "definition": "CHECK (((jsonb_typeof(summary) = 'object'::text) AND ((char_length(COALESCE((summary ->> 'vi'::text), ''::text)) >= 1) AND (char_length(COALESCE((summary ->> 'vi'::text), ''::text)) <= 1200)) AND ((char_length(COALESCE((summary ->> 'en'::text), ''::text)) >= 1) AND (char_length(COALESCE((summary ->> 'en'::text), ''::text)) <= 1200))))"
    },
    {
      "table_name": "book_editions",
      "conname": "book_editions_table_of_contents_shape",
      "contype": "c",
      "definition": "CHECK (((table_of_contents IS NULL) OR ((jsonb_typeof(table_of_contents) = 'object'::text) AND ((char_length(COALESCE((table_of_contents ->> 'vi'::text), ''::text)) >= 1) AND (char_length(COALESCE((table_of_contents ->> 'vi'::text), ''::text)) <= 5000)) AND ((char_length(COALESCE((table_of_contents ->> 'en'::text), ''::text)) >= 1) AND (char_length(COALESCE((table_of_contents ->> 'en'::text), ''::text)) <= 5000)))))"
    },
    {
      "table_name": "book_editions",
      "conname": "book_editions_weight_grams_range",
      "contype": "c",
      "definition": "CHECK (((weight_grams IS NULL) OR ((weight_grams >= 1) AND (weight_grams <= 50000))))"
    },
    {
      "table_name": "book_editions",
      "conname": "book_editions_work_id_fkey",
      "contype": "f",
      "definition": "FOREIGN KEY (work_id) REFERENCES book_works(id) ON UPDATE CASCADE ON DELETE RESTRICT"
    }
