# Required buyer-owned Supabase values.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public single-store identity. Replace every value during buyer onboarding.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_STORE_NAME=Bookstore Starter
NEXT_PUBLIC_STORE_SHORT_MARK=BS
NEXT_PUBLIC_STORE_TAGLINE_EN=Independent online bookstore
NEXT_PUBLIC_STORE_TAGLINE_VI=Nha sach truc tuyen
NEXT_PUBLIC_STORE_SUPPORT_PHONE=
NEXT_PUBLIC_STORE_SUPPORT_EMAIL=
NEXT_PUBLIC_STORE_SUPPORT_HOURS_EN=
NEXT_PUBLIC_STORE_SUPPORT_HOURS_VI=
NEXT_PUBLIC_STORE_LEGAL_NAME=Bookstore Starter
NEXT_PUBLIC_STORE_COPYRIGHT_YEAR=2026

# Optional server-owned VND/USD display estimate. VND remains authoritative.
# CASEFLOW_FX_VND_PER_USD=
# CASEFLOW_FX_SOURCE_LABEL=
# CASEFLOW_FX_SOURCE_URL=
# CASEFLOW_FX_QUOTED_AT=
# CASEFLOW_VAT_BASIS_POINTS=1000
# CASEFLOW_INTL_PAYMENT_FEE_BASIS_POINTS=300

# Payment providers are disabled by default. Do not enable a real provider by
# changing only these values; complete a provider-specific security review.
PAYMENT_MODE=disabled
ENABLE_MOCK_PAYMENT=false
CASEFLOW_MERCHANT_NAME=Bookstore Starter
DEMO_BANK_BIN=
DEMO_BANK_NAME=
DEMO_BANK_ACCOUNT_NUMBER=0000000000
DEMO_BANK_ACCOUNT_NAME=
DEMO_PAYMENT_EXPIRES_MINUTES=15
MOCK_PAYMENT_WEBHOOK_SECRET=

# External notification delivery is disabled until the buyer owns approved
# sender identities and credentials. In-app notifications remain supported.
NOTIFICATION_MODE=disabled
EMAIL_PROVIDER=disabled
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=
SMS_PROVIDER=disabled
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM=
OTP_HASH_SECRET=
NOTIFICATION_DISPATCH_SECRET=

# Buyer-isolated E2E environment. Never point these at the showroom project.
CASEFLOW_ADMIN_EMAIL=
CASEFLOW_ADMIN_PASSWORD=
PLAYWRIGHT_PORT=3001
PLAYWRIGHT_BASE_URL=
