# Required public Supabase runtime values. These are bundled for browser use.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required server-only runtime value. Never expose it through NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# Playwright only. Leave these unset in the deployed application runtime.
CASEFLOW_ADMIN_EMAIL=
CASEFLOW_ADMIN_PASSWORD=

# Optional Playwright overrides. Defaults are port 3001 and its local base URL.
# PLAYWRIGHT_PORT=3001
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3001
